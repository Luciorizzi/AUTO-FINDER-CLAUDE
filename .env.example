# === AutoFinder - Variables de Entorno ===

# --- Base de datos ---
DATABASE_PATH=data/autofinder.db

# --- Logging ---
# Nivel: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Navegador / Scraping ---
# true = sin ventana visible (produccion), false = con ventana (debug)
HEADLESS=true
# Maximo de resultados a extraer por query de busqueda
ML_MAX_RESULTS_PER_QUERY=48
# Maximo de paginas de detalle a visitar por corrida
ML_MAX_DETAIL_PAGES_PER_RUN=120
# Maximo de detalles a visitar por query individual (balance entre modelos)
ML_MAX_DETAILS_PER_QUERY=30
# Minimo garantizado de detalles por query (evita que queries chicas queden sin cobertura)
MIN_DETAILS_PER_QUERY=5
# Priorizar apertura de detalles por menor precio dentro de cada query
PRIORITIZE_LOWEST_PRICE_FIRST=true
# Capturar posicion y metadata del search para auditoria
ENABLE_SEARCH_POSITION_CAPTURE=true
# Pausa en segundos entre requests
SCRAPE_DELAY_SECONDS=2
# Timeout del navegador en ms
BROWSER_TIMEOUT_MS=30000
# User agent personalizado (dejar vacio para usar el default de Chromium)
USER_AGENT=

# --- Pricing ---
# Cantidad de listings a analizar por lote
PRICING_BATCH_SIZE=200
# Habilitar filtro de outliers IQR en precios de comparables
ENABLE_OUTLIER_FILTERING=true
# Habilitar deteccion y exclusion de publicaciones de anticipo/financiacion
ENABLE_FINANCING_FILTER=true
# Habilitar regla de dominancia (degrada oportunidades dominadas)
ENABLE_DOMINANCE_RULE=true

# --- Normalizacion ---
# Cantidad de listings a normalizar por lote
NORMALIZATION_BATCH_SIZE=200
# Habilitar deteccion de duplicados heuristicos
ENABLE_HEURISTIC_DEDUP=true
# Tolerancia de precio para considerar duplicado (%)
DUPLICATE_PRICE_TOLERANCE_PCT=5.0
# Tolerancia de km para considerar duplicado
DUPLICATE_MILEAGE_TOLERANCE=2000
# Permitir matching de modelos ambiguos (confianza baja)
ALLOW_AMBIGUOUS_MODELS=false

# --- Telegram (Fase 5+) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
